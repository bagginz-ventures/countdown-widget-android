<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="315"
                android:startColor="#71E6F7"
                android:endColor="#6C8CFF" />
        </shape>
    </item>
    <item android:insetLeft="10dp" android:insetTop="10dp" android:insetRight="10dp" android:insetBottom="10dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="#0F1726" />
        </shape>
    </item>
    <item android:insetLeft="20dp" android:insetTop="16dp" android:insetRight="20dp" android:insetBottom="16dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="#76E4F7" />
        </shape>
    </item>
</layer-list>
